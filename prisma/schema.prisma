// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  MERCHANT
}

enum NotificationType {
  MERCHANT_REJECTED
}

enum PromotionType {
  DISCOUNT
  BUNDLE
}

enum BundleType {
  PERCENTAGE_OFF
  FREE
}

enum Category {
  BEVERAGE
  PASTRY
  PASTA
  DESSERT
  BURGER
  PIZZA
  CHICKEN
  PORK
}

model User {
  id            String         @id @default(cuid())
  displayName   String
  email         String         @unique
  passwordHash  String
  role          UserRole
  merchant      Merchant?
  notifications Notification[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model Merchant {
  id                 String     @id @default(cuid())
  userId             String     @unique
  user               User       @relation(fields: [userId], references: [id])
  companyName        String
  phoneNumber        String     @unique
  verificationStatus Boolean
  taxId              String
  businesses         Business[]

  @@index([verificationStatus])
}

model Business {
  id                String      @id @default(cuid())
  merchantId        String
  merchant          Merchant    @relation(fields: [merchantId], references: [id])
  businessName      String
  dateEstablishment DateTime
  description       String
  coverPhoto        String
  menu              Menu[]
  promotion         Promotion[]
  branch            Branch[]
}

model Branch {
  id         String      @id @default(cuid())
  number     String
  building   String?
  street     String
  barangay   String
  city       String
  province   String
  businessId String
  business   Business    @relation(fields: [businessId], references: [id])
  promotion  Promotion[]
}

model Menu {
  id          String      @id @default(cuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id])
  itemName    String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  category    Category
  isAvailable Boolean
  promotion   Promotion[]
}

model Promotion {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  /// Branch where this promotion is effective (one business can have many branches)
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  /// Menu item this deal applies to
  menuId     String
  menu       Menu     @relation(fields: [menuId], references: [id])

  caption               String
  description           String
  /// Optional promo image; falls back to business coverPhoto when null/empty
  imageUrl              String?
  promotionType         PromotionType
  discountPercent       Int? // used only if promotionType==DISCOUNT
  bundleType            BundleType? // used only if promotionType==BUNDLE
  buyQuantity           Int? // used only if bundleType==FREE
  getQuantity           Int? // used only if bundleType==FREE
  bundleDiscountPercent Int? // used only if bundleType==PERCENTAGE_OFF
  startDate             DateTime
  endDate               DateTime
  archived              Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}
